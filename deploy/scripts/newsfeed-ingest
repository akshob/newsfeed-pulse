#!/bin/bash
# /usr/local/bin/newsfeed-ingest [model-name]
# Hourly pipeline: ingest → score → catchup-all.
# Pass the chat model as $1 (defaults to llama3.2:3b). Embeddings always
# use nomic-embed-text regardless.
#
# Timestamped per-run logs at /mnt/butterscotch/newsfeed-pulse/logs/ingest/
# flock prevents overlapping runs across both the daytime and overnight
# crontab entries.
set -e

MODEL="${1:-llama3.2:3b}"

APP_DIR=/mnt/butterscotch/newsfeed-pulse/app
LOG_DIR=/mnt/butterscotch/newsfeed-pulse/logs/ingest

mkdir -p "$LOG_DIR"
find "$LOG_DIR" -name 'ingest-*.log' -type f -mtime +30 -delete 2>/dev/null || true

TS=$(date -u +%Y-%m-%dT%H-%M-%SZ)
LOG="$LOG_DIR/ingest-$TS.log"

cd "$APP_DIR"
ln -sfn "$LOG" "$LOG_DIR/latest.log"

# Prevent overlapping runs (one shared lock across both crontab entries)
exec 9>/tmp/newsfeed-pipeline.lock
if ! flock -n 9; then
  echo "$(date -Iseconds) previous pipeline still running, skipping" >> "$LOG"
  exit 0
fi

exec >> "$LOG" 2>&1
echo "=== $(date -Iseconds) pipeline starting (pid $$, model=$MODEL) ==="

echo ''
echo '--- ingest ---'
./.build/release/NewsFeed ingest || echo '(ingest failed, continuing)'

echo ''
echo '--- score ---'
./.build/release/NewsFeed score --limit 100 --model "$MODEL" || echo '(score failed, continuing)'

echo ''
echo '--- catchup-all ---'
./.build/release/NewsFeed catchup-all --limit 50 --model "$MODEL" || echo '(catchup-all failed, continuing)'

echo ''
echo "=== $(date -Iseconds) pipeline done ==="

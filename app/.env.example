# Copy to .env and fill in real values. .env is gitignored.

# Postgres (create via: CREATE USER newsfeed; CREATE DATABASE newsfeed OWNER newsfeed; CREATE EXTENSION vector;)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=newsfeed
DATABASE_USERNAME=newsfeed
DATABASE_PASSWORD=change-me

# Vapor bind port (Caddy reverse-proxies to this)
PORT=8080

# Ollama hosts. Defaults to http://localhost:11434 for both embed + chat.
#
# In prod we split them: small embedder runs on the app server (no network hop,
# stays up even when the chat box is loaded/flaky), heavy chat runs on Apple
# Silicon with Metal. Either var falls back to OLLAMA_BASE_URL, which falls
# back to localhost — so single-host dev keeps working with no env at all.
# OLLAMA_EMBED_BASE_URL=http://localhost:11434
# OLLAMA_CHAT_BASE_URL=http://oxygen.local:11434
# OLLAMA_BASE_URL=http://oxygen.local:11434  # legacy single-host fallback

# Default chat model. Used by score (rerank/JSON) + catchup-all (explainer prose).
# This is a fallback; the cron entries pass the model explicitly per time-of-day:
#   overnight (1-6 AM):    bigger model (e.g. qwen2.5:32b)  — high quality
#   daytime (7 AM-12 AM):  smaller model (e.g. qwen2.5:7b)  — fast
# Embeddings always use nomic-embed-text (768-dim matches our pgvector schema).
# OLLAMA_CHAT_MODEL=llama3.2:3b

# Capture endpoint auth (optional; when set, POST /capture requires this token)
# CAPTURE_TOKEN=generate-a-random-string

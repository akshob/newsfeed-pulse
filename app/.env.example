# Copy to .env and fill in real values. .env is gitignored.

# Postgres (create via: CREATE USER newsfeed; CREATE DATABASE newsfeed OWNER newsfeed; CREATE EXTENSION vector;)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=newsfeed
DATABASE_USERNAME=newsfeed
DATABASE_PASSWORD=change-me

# Vapor bind port (Caddy reverse-proxies to this)
PORT=8080

# Ollama (optional override; defaults to http://localhost:11434)
# OLLAMA_BASE_URL=http://localhost:11434

# Ollama chat model used by both score (rerank/TLDR) and catchup-all (explainer).
# Defaults to llama3.2:3b. Try larger models if you've offloaded Ollama to a
# box with more RAM / Metal GPU acceleration:
#   llama3.1:8b       — ~6 GB RAM, strong general baseline
#   qwen2.5:7b        — similar size, often cleaner JSON
#   qwen2.5:14b       — ~10 GB RAM, notable quality step up (needs 16GB box)
# Embeddings always use nomic-embed-text (768-dim matches our pgvector schema).
# OLLAMA_CHAT_MODEL=llama3.2:3b

# Capture endpoint auth (optional; when set, POST /capture requires this token)
# CAPTURE_TOKEN=generate-a-random-string

# Copy to .env and fill in real values. .env is gitignored.

# Postgres (create via: CREATE USER newsfeed; CREATE DATABASE newsfeed OWNER newsfeed; CREATE EXTENSION vector;)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=newsfeed
DATABASE_USERNAME=newsfeed
DATABASE_PASSWORD=change-me

# Vapor bind port (Caddy reverse-proxies to this)
PORT=8080

# Ollama (optional override; defaults to http://localhost:11434)
# OLLAMA_BASE_URL=http://localhost:11434

# Capture endpoint auth (optional; when set, POST /capture requires this token)
# CAPTURE_TOKEN=generate-a-random-string
